{
  "compilerOptions": {
    "target": "es2016",                             
    "jsx": "react-jsx",                            
    "module": "commonjs",                           
    "allowJs": true,                                
    "checkJs": true,                                
    "esModuleInterop": true,                        
    "forceConsistentCasingInFileNames": true,       
    "strict": true,                                 
    "skipLibCheck": true                            
  }
}
